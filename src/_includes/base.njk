<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">

  {# Core text values #}
  {% set site_name = "Mariano Rozanski's Build Log" %}
  {% set default_description = "An engineer and founder’s build log documenting real AI-native, full-stack, and product experiments shipped under real constraints." %}
  {% set page_title = title or site_name %}
  {% set page_description = description or excerpt or default_description %}
  {% set social_image = social_image or "/assets/social/og-default.png" %}
  {% set canonical_url = "https://mrozanski.github.io" + (page.url or "") %}

  <title>
    {% if title %}{{ title }} - {% endif %}mrozanski (Mariano's Blog)
  </title>

  <meta name="description" content="{{ page_description }}">
  <meta name="author" content="Mariano Rozanski">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site_name }}">
  <meta property="og:title" content="{{ page_title }}">
  <meta property="og:description" content="{{ page_description }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:image" content="https://mrozanski.github.io{{ social_image }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page_title }}">
  <meta name="twitter:description" content="{{ page_description }}">
  <meta name="twitter:image" content="https://mrozanski.github.io{{ social_image }}">
  <!-- Optional if you want to wire your handle -->
  <!-- <meta name="twitter:site" content="@yourhandle"> -->
  <!-- <meta name="twitter:creator" content="@yourhandle"> -->

  <link rel="stylesheet" href="/style.css" type="text/css">
  <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
  <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>

<body class="{% if page.url == '/' %}home{% endif %}">
    <header class="page-header">
        <div class="header-content">
        <div class="header-left">
            <div class="cell cell-top">
            <!-- Top-left content: text and/or image -->
            <div class="title">
                    <div><a href="/">mrozanski</a></div>
                    <div class="site-name"><a href="/"><span class="first-cap">B</span>uild<span class="end-cap">LOG</span></a></div>
                </div>
            </div>
            <div class="border-line border-between-left" aria-hidden="true"></div>
            <div class="cell cell-bottom">
            <!-- Bottom-left content -->
            <p class="site-subtitle">Real projects where I use code, agents, and product thinking to ship faster</p>
            </div>
        </div>

        <div class="header-right">
            <!--div class="border-line border-top-right" aria-hidden="true"></div-->
            <div class="cell cell-top">
            <!-- Top-right content -->
            <ul class="menu">
                        <li class="menu-item"><a href="/about/">about</a></li>
                        <li class="menu-item"><a href="/posts/">posts</a></li>
                        <li class="menu-item"><a href="/contact/">contact</a></li>
                    </ul>
            </div>
            <div class="cell cell-bottom">
            <!-- Bottom-right content (taller) -->
            <img src="/assets/avatar.png" alt="Author avatar" class="avatar">
            </div>
        </div>
        </div>
    </header>
    

    <main>
        {% if tagline %}
        <div class="tagline">
            <p>{{ tagline }}</p>
        </div>
        {% endif %}

        <div class="content main-container">
            {{ content | safe }}
        </div>
    </main>

    <footer>
        <div class="wide-container">
            <div class="join-cta">
                <ul>
                    <li><a href="/contact" aria-label="Contact Form">Contact</a></li>
                    <li><a href="https://github.com/mrozanski" target="_blank" aria-label="GitHub">GitHub</a></li>
                    <li><a href="/rss.xml" aria-label="RSS">RSS</a></li>
                </ul>
            </div>
        </div>
    </footer>
</body>
</html>