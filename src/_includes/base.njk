<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    <title>{% if title %}{{ title }} - {% endif %}mrozanski (Mariano's Blog)</title>
    <link rel="stylesheet" href="/style.css" type="text/css">
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <script>
       function toggleMenu() {
            const menu = document.querySelector('.header-nav');
            console.log("Menu toggled");
            menu.classList.toggle('active');
        }
    </script>
</head>
<body>
    <header class="page-header">
        <div class="header-content">
        <div class="header-left">
            <div class="cell cell-top">
            <!-- Top-left content: text and/or image -->
            <div class="title">
                    <div><a href="/">mrozanski</a></div>
                    <div class="site-name"><span class="first-cap">B</span>uild<span class="end-cap">LOG</span></div>
                </div>
            </div>
            <div class="border-line border-between-left" aria-hidden="true"></div>
            <div class="cell cell-bottom">
            <!-- Bottom-left content -->
            <p class="site-subtitle">Real projects where I use code, agents, and product thinking to ship faster</p>
            </div>
        </div>

        <div class="header-center" aria-hidden="true">
            <!-- Central separator (no content) -->
        </div>

        <div class="header-right">
            <div class="border-line border-top-right" aria-hidden="true"></div>
            <div class="cell cell-top">
            <!-- Top-right content -->
            <ul class="menu">
                        <li class="menu-item"><a href="/about/">about</a></li>
                        <li class="menu-item"><a href="/posts/">posts</a></li>
                        <li class="menu-item"><a href="/contact/">contact</a></li>
                    </ul>
            </div>
            <div class="cell cell-bottom">
            <!-- Bottom-right content (taller) -->
            <img src="/avatar.png" alt="Author avatar" class="avatar">
            </div>
        </div>
        </div>
    </header>
    

    <main>
        {% if tagline %}
        <div class="tagline">
            <p>{{ tagline }}</p>
        </div>
        {% endif %}

        <div class="content main-container">
            {{ content | safe }}
        </div>
    </main>

    <footer>
        <div class="wide-container">
            <div class="join-cta">
                <ul>
                    <li><a href="mailto:mariano+blog@dotsur.co" aria-label="Email">Email</a></li>
                    <li><a href="https://github.com/mrozanski" target="_blank" aria-label="GitHub">GitHub</a></li>
                    <li><a href="/rss.xml" aria-label="RSS">RSS</a></li>
                </ul>
            </div>
        </div>
    </footer>
</body>
</html>